{
  "properties": {
    "init_token": {
      "anyOf": [{ "type": "string" }, { "type": "null" }],
      "title": "Init Token",
      "description": "Token de inicialização temporário (mostrado nos logs ao iniciar o servidor)"
    },
    "master_key": {
      "anyOf": [{ "type": "string" }, { "type": "null" }],
      "title": "Master Key",
      "description": "Master key configurada no arquivo .env"
    },
    "admin": {
      "description": "Dados do administrador inicial",
      "properties": {
        "nome": {
          "type": "string",
          "title": "Nome",
          "description": "Nome completo do administrador",
          "example": "Administrador do Sistema"
        },
        "email": {
          "type": "string",
          "format": "email",
          "title": "Email",
          "description": "Email do administrador",
          "example": "admin@sinapse.com"
        },
        "senha": {
          "type": "string",
          "minLength": 8,
          "title": "Senha",
          "description": "Senha do administrador (mínimo 8 caracteres)",
          "example": "Admin@123"
        },
        "telefone": {
          "anyOf": [{ "type": "string" }, { "type": "null" }],
          "title": "Telefone",
          "description": "Telefone do administrador",
          "example": "(11) 98765-4321"
        },
        "estado": {
          "anyOf": [{ "type": "string", "maxLength": 2 }, { "type": "null" }],
          "title": "Estado",
          "description": "Estado",
          "example": "SP"
        },
        "cidade": {
          "anyOf": [{ "type": "string" }, { "type": "null" }],
          "title": "Cidade",
          "description": "Cidade",
          "example": "São Paulo"
        },
        "funcao": {
          "anyOf": [{ "type": "string" }, { "type": "null" }],
          "title": "Funcao",
          "description": "Função/Cargo",
          "default": "Administrador do Sistema"
        },
        "instituicao": {
          "anyOf": [{ "type": "string" }, { "type": "null" }],
          "title": "Instituicao",
          "description": "Instituição",
          "default": "SINAPSE"
        }
      },
      "type": "object",
      "required": ["nome", "email", "senha"],
      "title": "AdminInitSchema",
      "x-readme-ref-name": "AdminInitSchema"
    }
  },
  "type": "object",
  "required": ["admin"],
  "title": "SystemInitializeSchema",
  "description": "Schema para inicialização do sistema.\n\nUse APENAS UMA das opções de autenticação:\n- init_token: Token temporário mostrado nos logs do servidor\n- master_key: Chave mestra configurada no .env",
  "example": {
    "admin": { "email": "admin@sinapse.com", "nome": "Administrador", "senha": "Admin@123" },
    "master_key": "sua_master_key_aqui"
  },
  "x-readme-ref-name": "SystemInitializeSchema"
}

{
  "properties": {
    "google_api_key": {
      "type": "string",
      "title": "Google Api Key",
      "description": "Google Places API key (obrigatório)"
    },
    "city": { "type": "string", "title": "City", "description": "Cidade para busca (obrigatório)" },
    "state": {
      "type": "string",
      "title": "State",
      "description": "Estado para busca (obrigatório)"
    },
    "country": {
      "anyOf": [{ "type": "string" }, { "type": "null" }],
      "title": "Country",
      "description": "País para busca (padrão: Brazil)",
      "default": "Brazil"
    },
    "search_terms": {
      "items": { "type": "string" },
      "type": "array",
      "minItems": 1,
      "title": "Search Terms",
      "description": "Lista de termos de pesquisa (ex: ['hospital', 'ubs', 'posto de saúde'])"
    },
    "term_type": {
      "anyOf": [{ "type": "string" }, { "type": "null" }],
      "title": "Term Type",
      "description": "Tipo de termo: 'establishment', 'keyword', ou 'type'",
      "default": "establishment"
    }
  },
  "type": "object",
  "required": ["google_api_key", "city", "state", "search_terms"],
  "title": "PlaceSearchRequest",
  "description": "Schema para busca de lugares com suporte a múltiplos termos.",
  "x-readme-ref-name": "PlaceSearchRequest"
}

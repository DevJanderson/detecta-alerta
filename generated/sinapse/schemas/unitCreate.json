      "maxLength": 100,
      "minLength": 2,
      "title": "Neighborhood",
      "description": "Bairro"
    },
    "city": {
      "type": "string",
      "maxLength": 100,
      "minLength": 2,
      "title": "City",
      "description": "Cidade"
    },
    "state": {
      "type": "string",
      "maxLength": 100,
      "minLength": 2,
      "title": "State",
      "description": "Estado"
    },

{
  "properties": {
    "titulo": { "type": "string", "maxLength": 500, "minLength": 1, "title": "Titulo" },
    "conteudo": { "type": "string", "minLength": 1, "title": "Conteudo" },
    "data_coleta": {
      "anyOf": [{ "type": "string", "format": "date" }, { "type": "string" }, { "type": "null" }],
      "title": "Data Coleta",
      "description": "Data do scraping (opcional, derivada no service)"
    },
    "url_fonte": {
      "anyOf": [{ "type": "string", "maxLength": 2000 }, { "type": "null" }],
      "title": "Url Fonte"
    },
    "fonte": {
      "anyOf": [{ "type": "string", "maxLength": 500 }, { "type": "null" }],
      "title": "Fonte"
    },
    "url_imagem": {
      "anyOf": [{ "type": "string", "maxLength": 1000 }, { "type": "null" }],
      "title": "Url Imagem",
      "description": "URL da imagem de capa"
    },
    "icone_fonte": {
      "anyOf": [{ "items": { "type": "string" }, "type": "array" }, { "type": "null" }],
      "title": "Icone Fonte",
      "description": "Array de URLs dos icones/logos das fontes"
    },
    "data_publicacao": {
      "anyOf": [
        { "type": "string", "format": "date-time" },
        { "type": "string", "format": "date" },
        { "type": "string" },
        { "type": "null" }
      ],
      "title": "Data Publicacao"
    },
    "descricao": { "anyOf": [{ "type": "string" }, { "type": "null" }], "title": "Descricao" },
    "data_evento": {
      "anyOf": [{ "type": "string", "format": "date" }, { "type": "string" }, { "type": "null" }],
      "title": "Data Evento"
    },
    "relevancia": {
      "type": "number",
      "maximum": 10,
      "minimum": 0,
      "title": "Relevancia",
      "default": 0
    },
    "status": {
      "type": "string",
      "pattern": "^(active|archived|flagged)$",
      "title": "Status",
      "default": "active"
    },
    "doencas": {
      "anyOf": [{ "items": { "type": "string" }, "type": "array" }, { "type": "null" }],
      "title": "Doencas",
      "description": "Lista de nomes de doencas"
    },
    "sintomas": {
      "anyOf": [{ "items": { "type": "string" }, "type": "array" }, { "type": "null" }],
      "title": "Sintomas",
      "description": "Lista de nomes de sintomas"
    },
    "localizacoes": {
      "anyOf": [
        {
          "items": {
            "anyOf": [
              { "type": "string" },
              {
                "properties": {
                  "pais": {
                    "type": "string",
                    "maxLength": 100,
                    "title": "Pais",
                    "description": "Nome do pais",
                    "default": "Brasil"
                  },
                  "estado": {
                    "anyOf": [{ "type": "string", "maxLength": 2 }, { "type": "null" }],
                    "title": "Estado",
                    "description": "Sigla do estado (ex: SP, RJ)"
                  },
                  "cidade": {
                    "anyOf": [{ "type": "string", "maxLength": 200 }, { "type": "null" }],
                    "title": "Cidade",
                    "description": "Nome da cidade"
                  }
                },
                "type": "object",
                "title": "LocalizacaoInput",
                "description": "Localizacao estruturada para criacao de noticias.\nFormato alternativo ao string 'Cidade,UF'.",
                "x-readme-ref-name": "LocalizacaoInput"
              }
            ]
          },
          "type": "array"
        },
        { "type": "null" }
      ],
      "title": "Localizacoes",
      "description": "Lista de localizacoes. Aceita strings ('Cidade,UF') ou objetos {pais, estado, cidade}"
    },
    "titulo_epidemiologico": {
      "anyOf": [{ "type": "string", "maxLength": 500 }, { "type": "null" }],
      "title": "Titulo Epidemiologico"
    },
    "tipo_evento": {
      "anyOf": [{ "type": "string", "maxLength": 50 }, { "type": "null" }],
      "title": "Tipo Evento"
    },
    "numero_casos": {
      "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }],
      "title": "Numero Casos"
    },
    "numero_mortes": {
      "anyOf": [{ "type": "integer", "minimum": 0 }, { "type": "null" }],
      "title": "Numero Mortes"
    },
    "fonte_oficial": {
      "anyOf": [{ "type": "string", "maxLength": 300 }, { "type": "null" }],
      "title": "Fonte Oficial"
    },
    "categoria": {
      "anyOf": [{ "type": "string", "maxLength": 50 }, { "type": "null" }],
      "title": "Categoria"
    },
    "classificacao_onehealth": {
      "anyOf": [{ "type": "string", "maxLength": 20 }, { "type": "null" }],
      "title": "Classificacao Onehealth",
      "description": "Classificacao One Health: Humana, Animal, Ambiental"
    },
    "doenca_principal": {
      "anyOf": [{ "type": "string", "maxLength": 200 }, { "type": "null" }],
      "title": "Doenca Principal",
      "description": "Doenca principal mencionada"
    },
    "tipo_contagem": {
      "anyOf": [{ "type": "string", "maxLength": 50 }, { "type": "null" }],
      "title": "Tipo Contagem",
      "description": "Tipo: novos_periodo, acumulado_ano, acumulado_historico, nao_epidemiologico, indeterminado"
    },
    "titulo_original": {
      "anyOf": [{ "type": "string", "maxLength": 500 }, { "type": "null" }],
      "title": "Titulo Original",
      "description": "Titulo original da materia jornalistica"
    },
    "cluster_id": {
      "anyOf": [{ "type": "string", "format": "uuid" }, { "type": "null" }],
      "title": "Cluster Id"
    },
    "artigos_relacionados": {
      "anyOf": [{ "items": { "type": "integer" }, "type": "array" }, { "type": "null" }],
      "title": "Artigos Relacionados",
      "description": "IDs de artigos relacionados (similaridade 70-89%)"
    }
  },
  "type": "object",
  "required": ["titulo", "conteudo"],
  "title": "NoticiaCreate",
  "description": "Schema para criacao de noticias.",
  "x-readme-ref-name": "NoticiaCreate"
}

# ===========================================
# Detecta Alerta - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e configure
# Solicite as URLs reais ao time de desenvolvimento

# API Base URL (pública - exposta ao cliente)
# - Staging: https://staging.exemplo.com/api/v1
# - Produção: https://api.exemplo.com/api/v1
NUXT_PUBLIC_API_BASE_URL=https://staging.exemplo.com/api/v1

# Sinapse API URL (privada - apenas server-side)
# URL base da API Sinapse para autenticação e dados (incluir /api/v1)
# - Staging: https://staging.sinapse.org.br/api/v1
# - Produção: https://api.sinapse.org.br/api/v1
NUXT_SINAPSE_API_URL=https://staging.sinapse.org.br/api/v1

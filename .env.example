# ===========================================
# Detecta Alerta - Variáveis de Ambiente
# ===========================================
# Copie este arquivo para .env e configure
# Solicite as URLs reais ao time de desenvolvimento

# ===========================================
# OBRIGATÓRIA (server-side)
# ===========================================

# Sinapse API URL (privada - apenas server-side BFF)
# URL base da API Sinapse para autenticação e dados
# IMPORTANTE: Incluir /api/v1 no final
#
# Ambientes:
# - Desenvolvimento: https://staging.sinapse.org.br/api/v1
# - Staging:         https://staging.sinapse.org.br/api/v1
# - Produção:        https://api-v2.sinapse.org.br/api/v1
NUXT_SINAPSE_API_URL=https://staging.sinapse.org.br/api/v1

# ===========================================
# OPCIONAL (não utilizada atualmente)
# ===========================================

# API Base URL (pública - exposta ao cliente)
# Reservada para uso futuro (chamadas diretas do cliente)
# NUXT_PUBLIC_API_BASE_URL=https://staging.sinapse.org.br/api/v1
